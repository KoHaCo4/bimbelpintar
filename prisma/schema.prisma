generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id         String       @id @default(uuid())
  email      String       @unique
  password   String
  role       Role         @default(SISWA)
  createdAt  DateTime     @default(now())
  name       String
  hasilUjian HasilUjian[]
  pembelian  Pembelian[]
}

model Soal {
  id             String       @id @default(uuid())
  judul          String
  mapel          Mapel
  kelas          Int
  deskripsi      String       @db.Text
  harga          Int
  jumlahSoal     Int
  durasi         Int
  createdAt      DateTime     @default(now())
  linkPembahasan String?
  hasilUjian     HasilUjian[]
  pembelian      Pembelian[]
  pertanyaan     Pertanyaan[]
}

model Pembelian {
  id        String   @id @default(uuid())
  userId    String
  soalId    String
  status    Status   @default(PENDING)
  createdAt DateTime @default(now())
  soal      Soal     @relation(fields: [soalId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@index([soalId], map: "Pembelian_soalId_fkey")
  @@index([userId], map: "Pembelian_userId_fkey")
}

model Pertanyaan {
  id         String    @id @default(uuid())
  soalId     String
  urutan     Int
  tipe       TipeSoal
  pertanyaan String    @db.Text
  createdAt  DateTime  @default(now())
  jawaban    Jawaban[]
  soal       Soal      @relation(fields: [soalId], references: [id], onDelete: Cascade)
  pilihan    Pilihan[]

  @@index([soalId], map: "Pertanyaan_soalId_fkey")
}

model Pilihan {
  id           String     @id @default(uuid())
  pertanyaanId String
  huruf        String
  teks         String     @db.Text
  isBenar      Boolean    @default(false)
  pertanyaan   Pertanyaan @relation(fields: [pertanyaanId], references: [id], onDelete: Cascade)

  @@index([pertanyaanId], map: "Pilihan_pertanyaanId_fkey")
}

model HasilUjian {
  id        String    @id @default(uuid())
  userId    String
  soalId    String
  skor      Float?
  selesaiAt DateTime?
  createdAt DateTime  @default(now())
  mulaiAt   DateTime  @default(now())
  soal      Soal      @relation(fields: [soalId], references: [id])
  user      User      @relation(fields: [userId], references: [id])
  jawaban   Jawaban[]

  @@index([soalId], map: "HasilUjian_soalId_fkey")
  @@index([userId], map: "HasilUjian_userId_fkey")
}

model Jawaban {
  id           String     @id @default(uuid())
  hasilUjianId String
  pertanyaanId String
  jawaban      String     @db.Text
  isBenar      Boolean?
  createdAt    DateTime   @default(now())
  hasilUjian   HasilUjian @relation(fields: [hasilUjianId], references: [id])
  pertanyaan   Pertanyaan @relation(fields: [pertanyaanId], references: [id])

  @@unique([hasilUjianId, pertanyaanId])
  @@index([pertanyaanId], map: "Jawaban_pertanyaanId_fkey")
}

enum Role {
  SISWA
  ADMIN
}

enum Mapel {
  MATEMATIKA
  IPA
  IPS
  BAHASA_INDONESIA
  BAHASA_INGGRIS
}

enum Status {
  PENDING
  SUCCESS
  FAILED
  CHALLENGE
  SETTLEMENT
  EXPIRE
  CANCEL
}

enum TipeSoal {
  PILIHAN_GANDA
  ESSAY
}
